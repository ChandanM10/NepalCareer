# NepalCareer Environment Configuration
# Copy this file to .env.local and fill in the actual values for your environment

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# SQLite (Development)
# DATABASE_URL="file:./dev.db"

# PostgreSQL (Production Recommended)
# PostgreSQL requires: postgresql://username:password@host:port/dbname
# Example: postgresql://nepalcareer:secure_password@db.example.com:5432/nepalcareer
DATABASE_URL="postgresql://username:password@localhost:5432/nepalcareer"

# ============================================================================
# NODE ENVIRONMENT
# ============================================================================
# Set to "production" when deploying to production servers
# Set to "development" for local development
NODE_ENV="development"

# ============================================================================
# SESSION & SECURITY
# ============================================================================
# Session cookie name (default is fine, can customize if needed)
SESSION_COOKIE="ajd_session"

# Next.js secret for encryption and session signing
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your_generated_secret_here_must_be_at_least_32_chars"

# ============================================================================
# EXTERNAL SERVICE INTEGRATION (Optional but Recommended for Production)
# ============================================================================

# Email Service (for notifications and alerts)
# Supported providers: sendgrid, mailgun, resend, nodemailer
EMAIL_PROVIDER="sendgrid"
EMAIL_FROM="noreply@nepalcareer.com"
SENDGRID_API_KEY="your_sendgrid_api_key_here"

# Alternative: Mailgun
# MAILGUN_DOMAIN="your_domain.mailgun.org"
# MAILGUN_API_KEY="your_mailgun_key_here"

# WhatsApp Integration (for job alerts and notifications)
# Supported providers: twilio, whatsapp_business_api
WHATSAPP_PROVIDER="twilio"
TWILIO_ACCOUNT_SID="your_twilio_account_sid"
TWILIO_AUTH_TOKEN="your_twilio_auth_token"
TWILIO_PHONE_NUMBER="+1234567890"

# ============================================================================
# EXTERNAL APIS (Optional)
# ============================================================================

# AI/LLM Services (for cover letter generation, interview prep, etc.)
# Supported: openai, anthropic
AI_PROVIDER="openai"
OPENAI_API_KEY="your_openai_api_key"
# or for Anthropic:
# ANTHROPIC_API_KEY="your_anthropic_api_key"

# Resume parsing service (for resume upload processing)
RESUME_PARSER_API="your_resume_parser_api_key"

# Job search aggregation (optional, for importing external job listings)
# LINKEDIN_API_KEY="your_linkedin_api_key"
# INDEED_API_KEY="your_indeed_api_key"

# ============================================================================
# DEPLOYMENT & HOSTING
# ============================================================================

# Base URL for your application
# Used for email links, redirects, etc.
NEXT_PUBLIC_BASE_URL="https://nepalcareer.com"

# File storage (for resumes, profile pictures, etc.)
# Supported: local, s3, gcs, azure
STORAGE_PROVIDER="s3"
S3_BUCKET_NAME="nepalcareer-files"
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID="your_s3_access_key"
S3_SECRET_ACCESS_KEY="your_s3_secret_key"

# ============================================================================
# MONITORING & LOGGING (Optional but Recommended for Production)
# ============================================================================

# Error tracking
SENTRY_DSN="your_sentry_dsn_for_error_tracking"

# Analytics
VERCEL_ANALYTICS_ID="your_analytics_id"

# Database monitoring
DATABASE_LOG_LEVEL="info"

# ============================================================================
# ADMIN ACCOUNT (used by seed.ts / setup-admin.ts)
# ============================================================================
# Set these to create/update the admin user. Never commit real values.
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="changeme123"
ADMIN_PHONE="+9779800000000"

# ============================================================================
# DEVELOPMENT ONLY (Remove or disable in production)
# ============================================================================

# Skip email sending in development (just log to console)
SKIP_EMAIL_SEND="true"

# Skip WhatsApp sending in development
SKIP_WHATSAPP_SEND="true"

# Seed test data on startup
SEED_TEST_DATA="false"

# ============================================================================
# PRODUCTION DEPLOYMENT CHECKLIST
# ============================================================================
# Before deploying to production:
#
# ✅ Change NODE_ENV to "production"
# ✅ Set DATABASE_URL to production PostgreSQL (NOT SQLite)
# ✅ Generate a new NEXTAUTH_SECRET using: openssl rand -base64 32
# ✅ Configure email service (SendGrid, Mailgun, etc.)
# ✅ Configure WhatsApp service (Twilio)
# ✅ Set NEXT_PUBLIC_BASE_URL to your production domain
# ✅ Configure S3 or other file storage
# ✅ Set up Sentry for error tracking
# ✅ Enable HTTPS everywhere
# ✅ Set up database backups
# ✅ Configure monitoring and alerting
# ✅ Test all authentication flows
# ✅ Test all notification delivery methods
# ✅ Load test the application
#
# For questions or issues, refer to the README.md documentation
